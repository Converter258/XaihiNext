{
  "name": "xn-frontend",
  "version": "0.1.0",
  "description": "XN Agent - Electron + Vue3 Frontend",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "vite build",
    "build": "tsc && vite build",
    "dev:renderer": "vite",
    "dev:electron": "tsc && cross-env NODE_ENV=development electron .",
    "start": "tsc && vite build && electron ."
  },
  "dependencies": {
    "axios": "^1.13.0",
    "marked": "^17.0.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/marked": "^5.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "typescript": "^5.9.0",
    "vite": "^6.3.0"
  }
}
